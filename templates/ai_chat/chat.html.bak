{% extends 'base.html' %}
{% block title %}Chat AI - Sora LMS{% endblock %}
{% block page_title %}Chat AI{% endblock %}

{% block extra_css %}
<style>
    .chat-wrapper {
        display: flex;
        gap: 1.25rem;
        height: calc(100vh - 130px);
    }

    /* Sidebar riwayat */
    .chat-sidebar {
        width: 260px;
        flex-shrink: 0;
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .chat-sidebar-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-session-list {
        flex: 1;
        overflow-y: auto;
        padding: 0.5rem;
    }

    .chat-session-item {
        padding: 0.65rem 0.85rem;
        border-radius: 10px;
        cursor: pointer;
        transition: background 0.15s;
        font-size: 0.82rem;
        color: #374151;
        border: 1.5px solid transparent;
        margin-bottom: 3px;
    }
    .chat-session-item:hover { background: #f8fafc; }
    .chat-session-item.active {
        background: #ede9fe;
        border-color: #c4b5fd;
        color: #5b21b6;
        font-weight: 600;
    }
    .chat-session-title {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .chat-session-date { font-size: 0.7rem; color: #94a3b8; margin-top: 2px; }

    /* Main chat area */
    .chat-main {
        flex: 1;
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-width: 0;
    }

    .chat-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        scroll-behavior: smooth;
    }

    /* Bubble */
    .msg-row {
        display: flex;
        gap: 0.75rem;
        animation: msgIn 0.2s ease-out;
    }
    @keyframes msgIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .msg-row.user { flex-direction: row-reverse; }

    .msg-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.8rem;
        color: white;
    }
    .msg-avatar.ai  { background: linear-gradient(135deg, #7c3aed, #6366f1); }
    .msg-avatar.usr { background: linear-gradient(135deg, #0ea5e9, #6366f1); }

    .msg-bubble {
        max-width: 72%;
        padding: 0.75rem 1rem;
        border-radius: 14px;
        font-size: 0.88rem;
        line-height: 1.65;
        color: #1e293b;
    }
    .msg-row.ai   .msg-bubble { background: #f8fafc; border: 1px solid #e2e8f0; border-top-left-radius: 4px; }
    .msg-row.user .msg-bubble { background: linear-gradient(135deg, #7c3aed, #6366f1); color: white; border-top-right-radius: 4px; }

    .msg-bubble pre {
        background: rgba(0,0,0,0.06);
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 0.8rem;
        overflow-x: auto;
        margin: 0.5rem 0 0;
        white-space: pre-wrap;
    }
    .msg-row.user .msg-bubble pre { background: rgba(255,255,255,0.15); color: white; }

    /* Typing indicator */
    .typing-indicator {
        display: flex;
        gap: 5px;
        padding: 0.75rem 1rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        border-top-left-radius: 4px;
        width: fit-content;
    }
    .typing-dot {
        width: 7px; height: 7px;
        background: #94a3b8;
        border-radius: 50%;
        animation: typingBounce 1.2s infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @keyframes typingBounce {
        0%, 60%, 100% { transform: translateY(0); }
        30% { transform: translateY(-6px); }
    }

    /* Input area */
    .chat-input-area {
        padding: 1rem 1.5rem;
        border-top: 1px solid #f1f5f9;
        background: white;
    }

    .chat-input-box {
        display: flex;
        gap: 0.75rem;
        align-items: flex-end;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 14px;
        padding: 0.65rem 0.75rem;
        transition: border-color 0.2s;
    }
    .chat-input-box:focus-within { border-color: #7c3aed; }

    #chatInput {
        flex: 1;
        border: none;
        background: transparent;
        resize: none;
        outline: none;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.88rem;
        color: #1e293b;
        max-height: 120px;
        line-height: 1.5;
    }

    .btn-send {
        width: 36px; height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #7c3aed, #6366f1);
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: opacity 0.15s;
    }
    .btn-send:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-send:hover:not(:disabled) { opacity: 0.85; }

    /* Empty state */
    .chat-empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        padding: 2rem;
        text-align: center;
    }
    .chat-empty .ai-icon {
        width: 64px; height: 64px;
        border-radius: 20px;
        background: linear-gradient(135deg, #7c3aed, #6366f1);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.75rem;
        margin-bottom: 1rem;
        box-shadow: 0 8px 24px rgba(124, 58, 237, 0.25);
    }

    .suggestion-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-top: 1rem; }
    .chip {
        padding: 0.45rem 0.9rem;
        background: #f1f5f9;
        border: 1.5px solid #e2e8f0;
        border-radius: 20px;
        font-size: 0.78rem;
        cursor: pointer;
        color: #475569;
        transition: all 0.15s;
    }
    .chip:hover { background: #ede9fe; border-color: #c4b5fd; color: #5b21b6; }

    @media (max-width: 768px) {
        .chat-sidebar { display: none; }
        .chat-wrapper { height: calc(100vh - 110px); }
    }
</style>
{% endblock %}

{% block content %}
<div class="chat-wrapper">

    <!-- Sidebar riwayat sesi -->
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <span class="fw-700" style="font-size:0.85rem; color:#1e293b;">Riwayat Chat</span>
            <button class="btn btn-sm" onclick="newSession()" title="Chat baru"
                    style="border:none; background:#ede9fe; color:#7c3aed; border-radius:8px; padding:0.3rem 0.6rem; font-size:0.78rem;">
                <i class="bi bi-plus-lg"></i>
            </button>
        </div>
        <div class="chat-session-list" id="sessionList">
            <!-- Diisi JS -->
        </div>
        <div style="padding:0.75rem 1rem; border-top:1px solid #f1f5f9;">
            <button onclick="clearAllData()" class="btn btn-sm w-100"
                    style="border:1.5px solid #fecaca; color:#ef4444; border-radius:8px; font-size:0.75rem; background:white;">
                <i class="bi bi-trash me-1"></i>Hapus Semua Riwayat
            </button>
        </div>
    </div>

    <!-- Main chat -->
    <div class="chat-main">
        <div class="chat-header">
            <div class="d-flex align-items-center gap-2">
                <div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#7c3aed,#6366f1);display:flex;align-items:center;justify-content:center;color:white;font-size:1rem;">
                    <i class="bi bi-stars"></i>
                </div>
                <div>
                    <div class="fw-700" style="font-size:0.9rem; color:#1e293b;" id="currentSessionTitle">Chat Baru</div>
                    <div style="font-size:0.7rem; color:#94a3b8;">Powered by Gemini AI</div>
                </div>
            </div>
            <button onclick="newSession()" class="btn btn-sm btn-outline-secondary" style="font-size:0.78rem; border-radius:8px;">
                <i class="bi bi-plus-lg me-1"></i>Baru
            </button>
        </div>

        <div class="chat-messages" id="chatMessages">
            <!-- Diisi JS -->
        </div>

        <div class="chat-input-area">
            <div class="chat-input-box">
                <textarea id="chatInput" rows="1" placeholder="Tanya apapun ke AI..." onkeydown="handleKey(event)"></textarea>
                <button class="btn-send" id="sendBtn" onclick="sendMessage()" disabled>
                    <i class="bi bi-send-fill" style="font-size:0.85rem;"></i>
                </button>
            </div>
            <div style="font-size:0.7rem; color:#94a3b8; text-align:center; margin-top:0.5rem;">
                AI bisa membuat kesalahan. Selalu verifikasi informasi penting.
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
const USER_KEY = 'sora_chat_{{ request.user.pk }}';
let sessions = {};
let currentSessionId = null;

// ─── Storage helpers ───────────────────────────────────────
function loadData() {
    try { sessions = JSON.parse(localStorage.getItem(USER_KEY) || '{}'); }
    catch { sessions = {}; }
}
function saveData() {
    localStorage.setItem(USER_KEY, JSON.stringify(sessions));
}

// ─── Session management ────────────────────────────────────
function newSession() {
    const id = 'sess_' + Date.now();
    sessions[id] = { title: 'Chat Baru', messages: [], createdAt: new Date().toISOString() };
    saveData();
    loadSession(id);
    renderSessionList();
}

function loadSession(id) {
    currentSessionId = id;
    const sess = sessions[id];
    document.getElementById('currentSessionTitle').textContent = sess.title;
    renderMessages();
    renderSessionList();
}

function renderSessionList() {
    const list = document.getElementById('sessionList');
    const ids = Object.keys(sessions).sort((a, b) => b.localeCompare(a));

    if (ids.length === 0) {
        list.innerHTML = '<div style="text-align:center; padding:2rem 1rem; color:#94a3b8; font-size:0.78rem;">Belum ada riwayat chat.</div>';
        return;
    }

    list.innerHTML = ids.map(id => {
        const s = sessions[id];
        const date = new Date(s.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'short' });
        return `<div class="chat-session-item ${id === currentSessionId ? 'active' : ''}" onclick="loadSession('${id}')">
            <div class="d-flex justify-content-between align-items-start">
                <div class="chat-session-title flex-grow-1">${escHtml(s.title)}</div>
                <button onclick="deleteSession(event,'${id}')" style="background:none;border:none;color:#94a3b8;padding:0 0 0 6px;font-size:0.75rem;" title="Hapus">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="chat-session-date">${date} · ${s.messages.length} pesan</div>
        </div>`;
    }).join('');
}

function deleteSession(e, id) {
    e.stopPropagation();
    if (!confirm('Hapus sesi chat ini?')) return;
    delete sessions[id];
    saveData();
    if (currentSessionId === id) {
        const remaining = Object.keys(sessions);
        if (remaining.length > 0) loadSession(remaining[remaining.length - 1]);
        else newSession();
    }
    renderSessionList();
}

function clearAllData() {
    if (!confirm('Hapus SEMUA riwayat chat kamu? Tidak bisa dikembalikan.')) return;
    localStorage.removeItem(USER_KEY);
    sessions = {};
    newSession();
}

// ─── Render messages ───────────────────────────────────────
function renderMessages() {
    const box = document.getElementById('chatMessages');
    const sess = sessions[currentSessionId];

    if (!sess || sess.messages.length === 0) {
        box.innerHTML = `
        <div class="chat-empty">
            <div class="ai-icon"><i class="bi bi-stars"></i></div>
            <div class="fw-700" style="font-size:1rem; color:#374151;">Halo, {{ request.user.get_full_name|default:request.user.username }}! 👋</div>
            <div style="font-size:0.83rem; margin-top:0.4rem;">Tanya apapun, saya siap membantu belajar.</div>
            <div class="suggestion-chips">
                <div class="chip" onclick="sendChip('Jelaskan cara membuat algoritma sorting')">Algoritma sorting</div>
                <div class="chip" onclick="sendChip('Apa itu machine learning?')">Machine learning</div>
                <div class="chip" onclick="sendChip('Bantu saya belajar matematika dasar')">Matematika dasar</div>
                <div class="chip" onclick="sendChip('Tips belajar yang efektif')">Tips belajar</div>
            </div>
        </div>`;
        return;
    }

    box.innerHTML = sess.messages.map(msg => renderBubble(msg.role, msg.content)).join('');
    box.scrollTop = box.scrollHeight;
}

function renderBubble(role, content) {
    const isUser = role === 'user';
    const avatar = isUser
        ? `<div class="msg-avatar usr">{{ request.user.username|slice:":1"|upper }}</div>`
        : `<div class="msg-avatar ai"><i class="bi bi-stars"></i></div>`;

    const formatted = formatContent(content);
    return `<div class="msg-row ${isUser ? 'user' : 'ai'}">
        ${isUser ? '' : avatar}
        <div class="msg-bubble">${formatted}</div>
        ${isUser ? avatar : ''}
    </div>`;
}

function formatContent(text) {
    // Bold
    text = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    // Code block
    text = text.replace(/```[\w]*\n?([\s\S]*?)```/g, '<pre>$1</pre>');
    // Inline code
    text = text.replace(/`([^`]+)`/g, '<code style="background:rgba(0,0,0,0.06);padding:0.1rem 0.35rem;border-radius:4px;font-size:0.82rem;">$1</code>');
    // Newline
    text = text.replace(/\n/g, '<br>');
    return text;
}

function escHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ─── Send message ──────────────────────────────────────────
async function sendMessage() {
    const input = document.getElementById('chatInput');
    const text = input.value.trim();
    if (!text || !currentSessionId) return;

    const sess = sessions[currentSessionId];
    sess.messages.push({ role: 'user', content: text });

    // Auto-title dari pesan pertama
    if (sess.messages.length === 1) {
        sess.title = text.slice(0, 40) + (text.length > 40 ? '…' : '');
        document.getElementById('currentSessionTitle').textContent = sess.title;
    }

    saveData();
    input.value = '';
    autoResize(input);
    renderMessages();
    setLoading(true);

    // Typing indicator
    const box = document.getElementById('chatMessages');
    const typing = document.createElement('div');
    typing.className = 'msg-row ai';
    typing.id = 'typingIndicator';
    typing.innerHTML = `<div class="msg-avatar ai"><i class="bi bi-stars"></i></div>
        <div class="typing-indicator">
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
        </div>`;
    box.appendChild(typing);
    box.scrollTop = box.scrollHeight;

    try {
        const res = await fetch('{% url "ai_chat:chat_api" %}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': getCsrf()
            },
            body: JSON.stringify({ messages: sess.messages })
        });

        const data = await res.json();
        typing.remove();

        if (data.error) {
            sess.messages.push({ role: 'assistant', content: '⚠️ ' + data.error });
        } else {
            sess.messages.push({ role: 'assistant', content: data.reply });
        }
    } catch (err) {
        typing.remove();
        sess.messages.push({ role: 'assistant', content: '⚠️ Gagal terhubung ke AI. Coba lagi.' });
    }

    saveData();
    renderMessages();
    renderSessionList();
    setLoading(false);
}

function sendChip(text) {
    document.getElementById('chatInput').value = text;
    sendMessage();
}

function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
    }
}

function setLoading(state) {
    document.getElementById('sendBtn').disabled = state;
}

// ─── Auto resize textarea ──────────────────────────────────
function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

document.getElementById('chatInput').addEventListener('input', function () {
    autoResize(this);
    document.getElementById('sendBtn').disabled = !this.value.trim();
});

// ─── CSRF ──────────────────────────────────────────────────
function getCsrf() {
    return document.cookie.split(';').map(c => c.trim())
        .find(c => c.startsWith('csrftoken='))?.split('=')[1] || '';
}

// ─── Init ──────────────────────────────────────────────────
loadData();
const existing = Object.keys(sessions);
if (existing.length > 0) {
    loadSession(existing.sort().reverse()[0]);
} else {
    newSession();
}
</script>
{% endblock %}
