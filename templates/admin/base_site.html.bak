{% extends "admin/base.html" %}
{% load static %}

{% block title %}{{ title }} | Sora LMS Admin{% endblock %}

{% block extrastyle %}
{{ block.super }}
<style>
    #result_list tbody a, 
    #result_list tbody th a {
        color: #ffffff !important;
        font-weight: bold !important;
    }    
    #content h1 {
        color: #ffffff !important;
    }
</style>
{% endblock %}

{% block branding %}
    <div class="brand-container" style="display: flex; align-items: center; gap: 15px; padding: 12px 20px;">
        <div class="brand-logo-wrapper" style="width: 45px; height: 45px; border-radius: 50%; overflow: hidden; background: #fff; display: flex; align-items: center; justify-content: center; border: 2px solid #06b6d4;">
            <img src="{% static 'images/logo.png' %}" alt="Sora LMS Logo" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        <div class="brand-text">
            <h1 style="margin: 0 !important; font-size: 1.3rem !important; font-weight: 700 !important; color: #f8fafc !important;">SORA LMS</h1>
            <span style="font-size: 0.7rem; text-transform: uppercase; color: #06b6d4; font-weight: 600; display: block;">Admin Control Panel</span>
        </div>
    </div>
{% endblock %}

{% block footer %}
    <div style="display: flex; justify-content: center; align-items: center; gap: 8px;">
        <span>&copy; {% now "Y" %} Sora LMS Admin</span>
        <span style="background: #092e20; color: #fff; padding: 2px 8px; border-radius: 4px; font-size: 10px;">Django Engine</span>
    </div>
{% endblock %}
